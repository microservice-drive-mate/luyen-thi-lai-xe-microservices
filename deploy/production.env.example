# Production env template for the legacy Docker Compose deploy path.
# Copy to the target VM/host, for example GCP Compute Engine, as .env and replace every change-me / replace-with-* value.
# Do not commit the real production .env.

COMPOSE_PROJECT_NAME=luyen-thi-lai-xe-production
NODE_ENV=production

# Image release
GHCR_OWNER=replace-with-github-owner
IMAGE_TAG=replace-with-git-sha-that-passed-ci

# Network exposure
PUBLIC_BIND=0.0.0.0
PRIVATE_BIND=127.0.0.1
VPS_PUBLIC_HOST=replace-with-gcp-vm-host-or-domain
GATEWAY_PUBLIC_URL=http://replace-with-prod-host-or-domain
KEYCLOAK_PUBLIC_URL=http://replace-with-prod-host-or-domain:8080
FRONTEND_ORIGIN=http://replace-with-frontend-origin
KONG_CORS_ORIGINS=http://replace-with-frontend-origin,http://replace-with-prod-host-or-domain

# Shared infrastructure
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me
RABBITMQ_DEFAULT_USER=app
RABBITMQ_DEFAULT_PASS=change-me
RABBITMQ_ERLANG_COOKIE=change-me-rabbitmq-cookie
REDIS_URL=redis://redis:6379

# Database names
IDENTITY_DB_NAME=identity_db
USER_DB_NAME=user_db
EXAM_DB_NAME=exam_db
COURSE_DB_NAME=course_db
QUESTION_DB_NAME=question_db
NOTIFICATION_DB_NAME=notification_db
ANALYTICS_DB_NAME=analytics_db
SIMULATION_DB_NAME=simulation_db
MEDIA_DB_NAME=media_db
AUDIT_DB_NAME=audit_db

# Keycloak
KEYCLOAK_DB_NAME=keycloak_db
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_AUTH_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=luyen-thi-lai-xe-realm
KEYCLOAK_CLIENT_ID=nestjs-backend
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_TIMEOUT_MS=10000
KEYCLOAK_COMMAND=start --import-realm
KEYCLOAK_HOSTNAME=replace-with-prod-host-or-domain
KEYCLOAK_HOSTNAME_STRICT=true
KEYCLOAK_HTTP_ENABLED=true
KEYCLOAK_PROXY_HEADERS=xforwarded

# Keycloak SMTP integration
KEYCLOAK_SMTP_HOST=replace-with-smtp-host
KEYCLOAK_SMTP_PORT=587
KEYCLOAK_SMTP_AUTH=true
KEYCLOAK_SMTP_USER=replace-with-smtp-user
KEYCLOAK_SMTP_PASSWORD=change-me
KEYCLOAK_SMTP_SSL=false
KEYCLOAK_SMTP_STARTTLS=true
KEYCLOAK_SMTP_FROM=no-reply@replace-with-domain
KEYCLOAK_SMTP_FROM_DISPLAY_NAME=Luyen Thi Lai Xe
KEYCLOAK_SMTP_REPLY_TO=no-reply@replace-with-domain
KEYCLOAK_SMTP_REPLY_TO_DISPLAY_NAME=Luyen Thi Lai Xe

# Media storage
STORAGE_ACCOUNT_NAME=replace-with-storage-account
STORAGE_ACCOUNT_KEY=change-me
STORAGE_CONTAINER_NAME=media
STORAGE_PRESIGNED_URL_EXPIRY=3600

# Service-to-service URLs and timeouts
QUESTION_SERVICE_URL=http://question-service:3000
USER_SERVICE_URL=http://user-service:3000
QUESTION_SERVICE_TIMEOUT_MS=3000
USER_SERVICE_TIMEOUT_MS=3000

# Consul production seed secrets
SECRET_IDENTITY_DB_URL=postgresql://user:change-me@db-identity:5432/identity_db
SECRET_USER_DB_URL=postgresql://user:change-me@db-user:5432/user_db
SECRET_EXAM_DB_URL=postgresql://user:change-me@db-exam:5432/exam_db
SECRET_COURSE_DB_URL=postgresql://user:change-me@db-course:5432/course_db
SECRET_QUESTION_DB_URL=postgresql://user:change-me@db-question:5432/question_db
SECRET_NOTIFICATION_DB_URL=postgresql://user:change-me@db-notification:5432/notification_db
SECRET_ANALYTICS_DB_URL=postgresql://user:change-me@db-analytics:5432/analytics_db
SECRET_SIMULATION_DB_URL=postgresql://user:change-me@db-simulation:5432/simulation_db
SECRET_MEDIA_DB_URL=postgresql://user:change-me@db-media:5432/media_db
SECRET_AUDIT_DB_URL=postgresql://user:change-me@db-audit:5432/audit_db
SECRET_RABBITMQ_URL=amqp://app:change-me@rabbitmq:5672
SECRET_RABBITMQ_USERNAME=app
SECRET_RABBITMQ_PASSWORD=change-me
SECRET_KEYCLOAK_CLIENT_SECRET=change-me
SECRET_STORAGE_ACCOUNT_KEY=change-me

# Logging and observability
LOG_LEVEL=info
LOG_FORMAT=json
LOG_CONSOLE_FORMAT=json
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5044
LOGSTASH_HOST_PORT=5044
CORS_ALLOWED_ORIGINS=http://replace-with-frontend-origin,http://replace-with-prod-host-or-domain
ELASTICSEARCH_URL=http://elasticsearch:9200
KIBANA_URL=http://kibana:5601
PROMETHEUS_URL=http://prometheus:9090
ALERTMANAGER_URL=http://alertmanager:9093
ALERTMANAGER_WEBHOOK_URL=http://replace-with-alert-webhook/alertmanager
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
ES_JAVA_OPTS=-Xms512m -Xmx512m

# Published ports
KONG_PROXY_PORT=80
KONG_ADMIN_PORT=8001
KEYCLOAK_PORT=8080
CONSUL_PORT=8500
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_PROMETHEUS_PORT=15692
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=30000

# Backup
BACKUP_RETENTION_DAYS=14
BACKUP_WEEKLY_RETENTION_WEEKS=4
BACKUP_INTERVAL_SECONDS=86400

# Manual deploy command inputs. These are for the operator/CI environment, not the remote .env file.
DEPLOY_ENV=production
DEPLOY_HOST=replace-with-gcp-vm-host-or-domain
DEPLOY_USER=replace-with-ssh-user
DEPLOY_PATH=/opt/luyen-thi-lai-xe
GHCR_USERNAME=replace-with-github-username
GHCR_TOKEN=change-me
PRISMA_CLI_VERSION=7.8.0
