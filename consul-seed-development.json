      "keycloak.clientId": "${KEYCLOAK_CLIENT_ID:-nestjs-backend}",
      "keycloak.clientSecret": "${KEYCLOAK_CLIENT_SECRET:-change-me}",
      "keycloak.timeoutMs": "${KEYCLOAK_TIMEOUT_MS:-10000}"
