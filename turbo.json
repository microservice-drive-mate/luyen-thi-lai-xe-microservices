{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "CONSUL_URL",
    "NODE_ENV",
    "RABBITMQ_URL",
    "RABBITMQ_HOST",
    "RABBITMQ_PORT",
    "RABBITMQ_USERNAME",
    "RABBITMQ_PASSWORD",
    "RABBITMQ_DEFAULT_USER",
    "RABBITMQ_DEFAULT_PASS",
    "RABBITMQ_DEBUG_CONFIG",
    "REDIS_URL",
    "LOGSTASH_HOST",
    "LOGSTASH_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["prisma:generate", "^build"],
      "outputs": ["dist/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },
    "lint": {
      "dependsOn": ["^build", "^lint"]
    },
    "check-types": {
      "dependsOn": ["prisma:generate", "^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:cov": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },

    "prisma:generate": {
      "outputs": []
    },
    "db:generate": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start:dev": {
      "dependsOn": ["^build"],
      "persistent": true
    },
    "test:load": {
      "cache": false
    },
    "test:soak": {
      "cache": false
    },
    "test:security": {
      "cache": false
    },
    "test:smoke": {
      "cache": false
    }
  }
}
