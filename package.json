{
  "name": "luyen-thi-lai-xe-microservices",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "tsx scripts/dev.ts",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check-types": "turbo run check-types",
    "prisma:generate": "turbo run prisma:generate",
    "db:generate": "turbo run db:generate",
    "db:migrate": "tsx scripts/prisma-migrate-all.ts dev",
    "db:deploy": "tsx scripts/prisma-migrate-all.ts deploy",
    "db:seed": "tsx scripts/prisma-seed-all.ts",
    "db:seed:question": "tsx scripts/prisma-seed-all.ts question-service",
    "db:seed:question-images": "tsx scripts/seed-question-images.ts",
    "db:backup:local": "tsx scripts/db-backup-local.ts",
    "db:backup:once": "docker compose -f docker-compose.infra.yml run --rm -e BACKUP_RUN_ONCE=true postgres-backup",
    "keycloak:backup:once": "docker compose -f docker-compose.infra.yml run --rm -e BACKUP_RUN_ONCE=true keycloak-backup",
    "db:restore:test": "tsx scripts/db-restore-test.ts",
    "smoke": "tsx scripts/smoke.ts",
    "observability:smoke": "tsx scripts/observability-smoke.ts",
    "rabbitmq:smoke": "tsx scripts/rabbitmq-resilience-smoke.ts",
    "deployment:record": "node scripts/devops-record-deployment.js",
    "dora:report": "tsx scripts/devops-dora-report.ts",
    "dora:export-prometheus": "tsx scripts/devops-dora-prometheus-export.ts",
    "infra:up": "docker compose -f docker-compose.infra.yml up -d",
    "infra:down": "docker compose -f docker-compose.infra.yml down",
    "infra:logs": "docker compose -f docker-compose.infra.yml logs -f",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:migrate": "tsx scripts/prisma-migrate-all.ts deploy development-local",
    "consul:seed": "tsx scripts/consul-seed.ts",
    "consul:seed:local": "tsx scripts/consul-seed.ts development-local",
    "consul:list": "tsx scripts/consul-list.ts",
    "consul:get": "tsx scripts/consul-get.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "optionalDependencies": {
    "@biomejs/cli-linux-x64": "2.4.13",
    "@biomejs/cli-win32-x64": "2.4.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.7.4",
    "tsx": "^4.7.0",
    "turbo": "^2.9.1",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@nestjs/config": "^4.0.4",
    "@nestjs/microservices": "^11.1.17",
    "@repo/common": "^1.0.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.3",
    "axios": "^1.6.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "joi": "^17.11.0",
    "keycloak-connect": "^26.1.1",
    "quickjs-wasi": "^2.2.0"
  }
}
