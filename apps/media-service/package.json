{
  "name": "media-service",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "check-types": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:migrate": "tsx ../../scripts/with-consul-env.ts media-service -- prisma migrate dev --schema ./prisma/schema.prisma",
    "db:deploy": "tsx ../../scripts/with-consul-env.ts media-service -- prisma migrate deploy --schema ./prisma/schema.prisma",
    "db:studio": "tsx ../../scripts/with-consul-env.ts media-service -- prisma studio --schema ./prisma/schema.prisma"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.26.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@repo/common": "^1.0.0",
    "amqplib": "^0.10.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "keycloak-connect": "^26.1.1",
    "multer": "^1.4.5-lts.1",
    "nest-keycloak-connect": "^1.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/amqplib": "^0.10.5",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
