# ================================================
# identity-service - Environment Variables
# ================================================
# Copy file này thành .env và điền giá trị thật
# File .env đã được gitignore - không commit lên git

# Consul Config Server
# Khi Consul chạy (Docker): dùng Consul để load config
# Khi Consul không chạy: fallback xuống các biến bên dưới
CONSUL_URL=http://localhost:8500

# App
NODE_ENV=development-local
PORT=3001

# Database (chỉ dùng khi Consul không chạy)
# Nếu DB trong Docker và đã expose port: localhost:5432
# Nếu chạy full Docker: postgresql://user:password@db-identity:5432/identity_db
DATABASE_URL=postgresql://user:password@localhost:5432/identity_db

# RabbitMQ (chỉ dùng khi Consul không chạy)
RABBITMQ_URL=amqp://localhost:5672
