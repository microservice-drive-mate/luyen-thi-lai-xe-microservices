generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/@prisma/exam-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum LicenseCategory {
  A1
  A2
  B1
  B2
  C
  D
  E
  F
}

enum ExamSessionStatus {
  IN_PROGRESS
  COMPLETED
  TIMED_OUT
  CANCELLED
}

model ExamTemplate {
  id              String          @id @default(uuid())
  name            String          @db.Text
  description     String?         @db.Text
  licenseCategory LicenseCategory
  totalQuestions  Int
  passingScore    Int
  durationMinutes Int
  criticalQuestions Int           @default(0)
  maxCriticalMistakes Int         @default(0)
  shuffleQuestions Boolean        @default(true)
  topicDistribution Json          @default("[]")
  isActive        Boolean         @default(true)
  isDeleted       Boolean         @default(false)
  version         Int             @default(1)
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  sessions ExamSession[]

  @@index([licenseCategory, isActive, isDeleted])
  @@map("exam_templates")
}

model ExamSession {
  id               String            @id @default(uuid())
  studentId        String
  templateId       String
  templateNameSnapshot String          @default("")
  templateVersionSnapshot Int          @default(1)
  licenseCategorySnapshot LicenseCategory @default(B1)
  totalQuestionsSnapshot Int           @default(0)
  passingScoreSnapshot Int             @default(0)
  durationMinutesSnapshot Int          @default(0)
  criticalQuestionsSnapshot Int        @default(0)
  topicDistributionSnapshot Json       @default("[]")
  status           ExamSessionStatus @default(IN_PROGRESS)
  score            Int?
  isPassed         Boolean?
  failedByCritical Boolean           @default(false)
  criticalMistakes Int               @default(0)
  maxCriticalMistakes Int            @default(0)
  startedAt        DateTime          @default(now())
  finishedAt       DateTime?
  expiresAt        DateTime
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  template  ExamTemplate          @relation(fields: [templateId], references: [id])
  questions ExamSessionQuestion[]

  @@index([studentId, status])
  @@index([studentId, startedAt])
  @@index([studentId, isPassed, startedAt])
  @@index([startedAt, isPassed])
  @@index([templateId])
  @@map("exam_sessions")
}

model ExamSessionQuestion {
  id               String   @id @default(uuid())
  sessionId        String
  questionId       String
  questionContent  String   @db.Text
  imageUrl         String?
  mediaFileId      String?
  optionsSnapshot  Json
  correctOptionId  String
  isCritical       Boolean
  displayOrder     Int
  selectedOptionId String?
  isCorrect        Boolean?
  isBookmarked     Boolean  @default(false)
  answeredAt       DateTime?

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@unique([sessionId, displayOrder])
  @@map("exam_session_questions")
}

enum OutboxMessageStatus {
  PENDING
  PUBLISHED
  FAILED
}

model OutboxMessage {
  id            String              @id @default(uuid())
  eventName     String
  payload       Json
  status        OutboxMessageStatus @default(PENDING)
  attempts      Int                 @default(0)
  nextAttemptAt DateTime            @default(now())
  publishedAt   DateTime?
  lastError     String?             @db.Text
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([status, nextAttemptAt])
  @@map("outbox_messages")
}
