generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/@prisma/notification-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
  IN_APP
  EMAIL
  PUSH
  SMS
}

enum AcademicWarningDeliveryStatus {
  PENDING
  QUEUED
  PENDING_RETRY
  FAILED
  SENT
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType @default(IN_APP)
  title     String           @db.Text
  body      String           @db.Text
  data      Json             @default("{}")
  isRead    Boolean          @default(false)
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model AcademicWarning {
  id          String   @id @default(uuid())
  studentId   String
  reason      String   @db.Text
  severity    String
  message     String   @db.Text
  createdById String
  deliveryStatus AcademicWarningDeliveryStatus @default(PENDING)
  retryAttempts  Int      @default(0)
  nextRetryAt    DateTime?
  notificationId String?
  lastError      String?  @db.Text
  queuedAt       DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId, createdAt])
  @@index([deliveryStatus, nextRetryAt])
  @@map("academic_warnings")
}
