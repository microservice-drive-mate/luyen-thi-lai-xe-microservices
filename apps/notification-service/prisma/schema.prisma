generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/@prisma/notification-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
  IN_APP
  EMAIL
  PUSH
  SMS
}

enum NotificationStatus {
  PENDING
  QUEUED
  DELIVERED
  FAILED
}

enum AcademicWarningDeliveryStatus {
  PENDING
  QUEUED
  PENDING_RETRY
  FAILED
  SENT
}

model Notification {
  id           String             @id @default(uuid())
  userId       String
  type         NotificationType   @default(IN_APP)
  eventType    String?
  title        String             @db.Text
  body         String             @db.Text
  data         Json               @default("{}")
  status       NotificationStatus @default(DELIVERED)
  retryCount   Int                @default(0)
  errorMessage String?            @db.Text
  isRead       Boolean            @default(false)
  readAt       DateTime?
  sentAt       DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([userId, isRead, createdAt])
  @@index([userId, status])
  @@map("notifications")
}

model NotificationPreference {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  inAppEnabled           Boolean  @default(true)
  emailEnabled           Boolean  @default(true)
  pushEnabled            Boolean  @default(false)
  smsEnabled             Boolean  @default(false)
  studyReminderEnabled   Boolean  @default(true)
  examReminderEnabled    Boolean  @default(true)
  courseUpdateEnabled    Boolean  @default(true)
  academicWarningEnabled Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("notification_preferences")
}

model AcademicWarning {
  id             String                        @id @default(uuid())
  studentId      String
  reason         String                        @db.Text
  severity       String
  message        String                        @db.Text
  createdById    String
  deliveryStatus AcademicWarningDeliveryStatus @default(PENDING)
  retryAttempts  Int                           @default(0)
  nextRetryAt    DateTime?
  notificationId String?
  lastError      String?                       @db.Text
  queuedAt       DateTime?
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt

  @@index([studentId, createdAt])
  @@index([deliveryStatus, nextRetryAt])
  @@map("academic_warnings")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("device_tokens")
}
