generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/@prisma/notification-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
  IN_APP
  EMAIL
  PUSH
  SMS
}

enum NotificationStatus {
  PENDING
  QUEUED
  DELIVERED
  FAILED
}

model Notification {
  id           String             @id @default(uuid())
  userId       String
  type         NotificationType   @default(IN_APP)
  eventType    String?
  title        String             @db.Text
  body         String             @db.Text
  data         Json               @default("{}")
  status       NotificationStatus @default(DELIVERED)
  retryCount   Int                @default(0)
  errorMessage String?            @db.Text
  isRead       Boolean            @default(false)
  readAt       DateTime?
  sentAt       DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([userId, isRead, createdAt])
  @@index([userId, status])
  @@map("notifications")
}

model AcademicWarning {
  id          String   @id @default(uuid())
  studentId   String
  reason      String   @db.Text
  severity    String
  message     String   @db.Text
  createdById String
  createdAt   DateTime @default(now())

  @@index([studentId, createdAt])
  @@map("academic_warnings")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("device_tokens")
}
