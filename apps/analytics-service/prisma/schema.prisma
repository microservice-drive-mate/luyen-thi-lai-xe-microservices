generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/@prisma/analytics-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model StudentLearningProfile {
  id                String    @id
  studentId         String    @unique
  totalStudyMinutes Int       @default(0)
  totalExamAttempts Int       @default(0)
  passedExams       Int       @default(0)
  avgExamScore      Float     @default(0)
  coursesEnrolled   Int       @default(0)
  coursesCompleted  Int       @default(0)
  lastActivityAt    DateTime?
  resetAt           DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("student_learning_profiles")
}

model DailyActivity {
  id                String   @id @default(uuid())
  studentId         String
  date              DateTime @db.Date
  studyMinutes      Int      @default(0)
  questionsAnswered Int      @default(0)
  correctAnswers    Int      @default(0)
  examsAttempted    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([studentId, date])
  @@index([studentId, date])
  @@map("daily_activities")
}

model QuestionAccuracyTracker {
  id              String   @id @default(uuid())
  studentId       String
  questionId      String
  topicId         String?
  topicName       String?
  totalAttempts   Int      @default(0)
  correctAttempts Int      @default(0)
  lastAttemptAt   DateTime @default(now())

  @@unique([studentId, questionId])
  @@index([studentId, lastAttemptAt])
  @@map("question_accuracy_trackers")
}

model DashboardUserProjection {
  id          String   @id @default(uuid())
  userId      String   @unique
  fullName    String?
  email       String?
  role        String
  isActive    Boolean  @default(true)
  licenseTier String?
  createdAt   DateTime
  updatedAt   DateTime

  @@index([role, createdAt])
  @@index([licenseTier, createdAt])
  @@map("dashboard_user_projections")
}

model DashboardCourseProjection {
  id              String   @id @default(uuid())
  courseId        String   @unique
  title           String?
  licenseCategory String
  status          String
  isDeleted       Boolean  @default(false)
  createdAt       DateTime
  updatedAt       DateTime

  @@index([status, createdAt])
  @@index([licenseCategory, createdAt])
  @@map("dashboard_course_projections")
}

model DashboardExamSessionProjection {
  id              String   @id @default(uuid())
  sessionId       String   @unique
  studentId       String
  licenseCategory String
  score           Int?
  isPassed        Boolean
  completedAt     DateTime

  @@index([completedAt])
  @@index([licenseCategory, completedAt])
  @@index([isPassed, completedAt])
  @@map("dashboard_exam_session_projections")
}

model DashboardRecentActivityProjection {
  id              String   @id @default(uuid())
  eventId         String   @unique
  type            String
  title           String
  description     String
  actorId         String?
  actorName       String?
  resourceType    String?
  resourceId      String?
  licenseCategory String?
  occurredAt      DateTime

  @@index([occurredAt])
  @@index([type, occurredAt])
  @@map("dashboard_recent_activity_projections")
}

model DashboardProcessedEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  eventName   String
  processedAt DateTime @default(now())

  @@index([eventId])
  @@map("dashboard_processed_events")
}
