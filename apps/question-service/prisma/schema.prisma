generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/@prisma/question-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum LicenseCategory {
  A1
  A2
  B1
  B2
  C
  D
  E
  F
}

enum QuestionType {
  THEORY
  TRAFFIC_SIGN
  SCENARIO_RELATED
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

model QuestionTopic {
  id          String   @id @default(uuid())
  name        String   @db.Text
  description String?  @db.Text
  parentId    String?
  createdAt   DateTime @default(now())

  parent    QuestionTopic?  @relation("TopicHierarchy", fields: [parentId], references: [id])
  children  QuestionTopic[] @relation("TopicHierarchy")
  questions Question[]

  @@map("question_topics")
}

model Question {
  id                String             @id @default(uuid())
  content           String             @db.Text
  type              QuestionType
  licenseCategories LicenseCategory[]
  difficulty        QuestionDifficulty
  explanation       String             @db.Text
  imageUrl          String?
  mediaFileId       String?
  isCritical        Boolean            @default(false)
  isActive          Boolean            @default(true)
  isDeleted         Boolean            @default(false)
  topicId           String
  createdById       String
  version           Int                @default(1)
  deletedById       String?
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  topic   QuestionTopic    @relation(fields: [topicId], references: [id])
  options QuestionOption[]
  versions QuestionVersion[]
  reports QuestionReport[]

  @@index([topicId])
  @@index([topicId, isActive, isDeleted])
  @@index([isActive, isDeleted])
  @@index([createdAt])
  @@index([licenseCategories], type: Gin)
  // ASR-PERF-11: pg_trgm GIN index enables fast ILIKE keyword search on content
  // Requires CREATE EXTENSION IF NOT EXISTS pg_trgm (added to migration)
  @@index([content(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_questions_content_trgm")
  @@map("questions")
}

model QuestionVersion {
  id                String             @id @default(uuid())
  questionId        String
  version           Int
  content           String             @db.Text
  type              QuestionType
  licenseCategories LicenseCategory[]
  difficulty        QuestionDifficulty
  explanation       String             @db.Text
  imageUrl          String?
  mediaFileId       String?
  isCritical        Boolean
  isActive          Boolean
  topicId           String
  optionsSnapshot   Json
  createdAt         DateTime           @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, version])
  @@index([questionId, createdAt])
  @@map("question_versions")
}

model QuestionOption {
  id           String  @id @default(uuid())
  questionId   String
  content      String  @db.Text
  isCorrect    Boolean
  displayOrder Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, displayOrder])
  @@map("question_options")
}

model QuestionReport {
  id         String   @id @default(uuid())
  questionId String
  userId     String
  reason     String
  message    String?  @db.Text
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, status])
  @@index([userId, createdAt])
  @@map("question_reports")
}
