generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/@prisma/user-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CENTER_MANAGER
  INSTRUCTOR
  STUDENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum LicenseTier {
  A1
  A2
  B1
  B2
  C
  D
  E
  F
}

enum UserDocumentType {
  ID_CARD_FRONT
  ID_CARD_BACK
  PORTRAIT
  HEALTH_CERTIFICATE
  OTHER
}

enum UserDocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model UserProfile {
  id          String    @id
  fullName    String
  email       String    @unique
  phoneNumber String?   @unique
  dateOfBirth DateTime?
  avatarUrl   String?
  mediaFileId String?
  gender      Gender?
  address     String?
  role        Role
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  studentDetail           StudentDetail?
  licenseAssignmentAudits LicenseAssignmentAudit[]
  documents               UserDocument[]

  @@map("user_profiles")
  // ASR-PERF-02: pg_trgm GIN indexes for ILIKE-based user search across all searchable fields.
  // PostgreSQL's bitmap index OR-scan combines these 3 indexes when the query
  // uses OR conditions: fullName ILIKE | email ILIKE | phoneNumber ILIKE.
  // Requires CREATE EXTENSION IF NOT EXISTS pg_trgm (added to migration).
  @@index([fullName(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_user_profiles_fullname_trgm")
  @@index([email(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_user_profiles_email_trgm")
  @@index([phoneNumber(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_user_profiles_phone_trgm")
}

model UserDocument {
  id          String             @id @default(uuid())
  userId      String
  type        UserDocumentType
  mediaFileId String
  title       String?
  status      UserDocumentStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([mediaFileId])
  @@map("user_documents")
}

model StudentDetail {
  id          String      @id @default(uuid())
  studentId   String      @unique
  licenseTier LicenseTier?
  enrolledAt  DateTime?
  notes       String?

  student UserProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_details")
}

model LicenseAssignmentAudit {
  id             String      @id @default(uuid())
  studentId      String
  oldLicenseTier LicenseTier?
  newLicenseTier LicenseTier
  changedById    String
  changedAt      DateTime    @default(now())

  student UserProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("license_assignment_audits")
}

enum OutboxMessageStatus {
  PENDING
  PUBLISHED
  FAILED
}

model OutboxMessage {
  id            String              @id @default(uuid())
  eventName     String
  payload       Json
  status        OutboxMessageStatus @default(PENDING)
  attempts      Int                 @default(0)
  nextAttemptAt DateTime            @default(now())
  publishedAt   DateTime?
  lastError     String?             @db.Text
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([status, nextAttemptAt])
  @@map("outbox_messages")
}
