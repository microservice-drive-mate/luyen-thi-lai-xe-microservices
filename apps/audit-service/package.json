{
  "name": "audit-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prebuild": "npm run prisma:generate",
    "precheck-types": "npm run prisma:generate",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "node --watch --watch-path=src --watch-preserve-output -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "start:prod": "node dist/src/main.js",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:migrate": "tsx ../../scripts/with-consul-env.ts audit-service -- prisma migrate dev --schema ./prisma/schema.prisma",
    "db:deploy": "tsx ../../scripts/with-consul-env.ts audit-service -- prisma migrate deploy --schema ./prisma/schema.prisma",
    "check-types": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@repo/common": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "joi": "^17.11.0",
    "keycloak-connect": "^26.1.1",
    "nest-keycloak-connect": "^1.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "jest": "^30.0.0",
    "prisma": "^7.8.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
