project_id = "replace-with-your-gcp-project-id"

# Phase 9 defaults: one e2-standard-8 VM in Singapore.
project_name = "luyen-thi-lai-xe"
environment  = "staging"
region       = "asia-southeast1"
zone         = "asia-southeast1-b"

machine_type      = "e2-standard-8"
boot_disk_size_gb = 150
boot_disk_type    = "pd-balanced"
image             = "ubuntu-os-cloud/ubuntu-2204-lts"

# Create one if needed:
# ssh-keygen -t rsa -b 4096 -C "your_email@example.com"
ssh_user            = "ubuntu"
ssh_public_key_path = "~/.ssh/id_rsa.pub"

# Replace with your public IP/CIDR before terraform plan/apply.
# Example: allowed_admin_cidrs = ["203.0.113.10/32"]
allowed_admin_cidrs = ["replace-with-your-public-ip/32"]

k3s_version  = "v1.29.4+k3s1"
network_cidr = "10.90.0.0/24"
