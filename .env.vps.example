# Legacy VM/Compose env example. For GCP, use a Compute Engine host/domain here if you still run Docker Compose.

NODE_ENV=production
PUBLIC_BIND=0.0.0.0
PRIVATE_BIND=127.0.0.1

VPS_PUBLIC_HOST=replace-with-gcp-vm-host-or-domain
GATEWAY_PUBLIC_URL=http://replace-with-gcp-vm-host-or-domain:8000
KEYCLOAK_PUBLIC_URL=http://replace-with-gcp-vm-host-or-domain:8080
FRONTEND_ORIGIN=http://replace-with-frontend-origin
KONG_CORS_ORIGINS=http://replace-with-frontend-origin,http://replace-with-gcp-vm-host-or-domain,http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

GHCR_OWNER=replace-with-github-owner
IMAGE_TAG=latest

KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001
KEYCLOAK_PORT=8080
CONSUL_PORT=8500
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_PROMETHEUS_PORT=15692
ELASTICSEARCH_PORT=9200
LOGSTASH_HOST_PORT=5044
KIBANA_PORT=5601
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=30000

POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-strong-postgres-password
RABBITMQ_DEFAULT_USER=app
RABBITMQ_DEFAULT_PASS=change-me-strong-rabbitmq-password
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me-strong-keycloak-db-password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-strong-keycloak-admin-password
KEYCLOAK_REALM=luyen-thi-lai-xe-realm
KEYCLOAK_CLIENT_ID=nestjs-backend
KEYCLOAK_CLIENT_SECRET=change-me-keycloak-client-secret
KEYCLOAK_AUTH_SERVER_URL=http://replace-with-gcp-vm-host-or-domain:8080
KEYCLOAK_HOSTNAME=replace-with-gcp-vm-host-or-domain
KEYCLOAK_HOSTNAME_STRICT=false
KEYCLOAK_HTTP_ENABLED=true
KEYCLOAK_PROXY_HEADERS=xforwarded
KEYCLOAK_COMMAND=start-dev --import-realm

IDENTITY_DB_NAME=identity_db
USER_DB_NAME=user_db
EXAM_DB_NAME=exam_db
COURSE_DB_NAME=course_db
QUESTION_DB_NAME=question_db
NOTIFICATION_DB_NAME=notification_db
ANALYTICS_DB_NAME=analytics_db
SIMULATION_DB_NAME=simulation_db
MEDIA_DB_NAME=media_db
AUDIT_DB_NAME=audit_db
KEYCLOAK_DB_NAME=keycloak_db

SECRET_IDENTITY_DB_URL=postgresql://app:change-me-strong-postgres-password@db-identity:5432/identity_db
SECRET_USER_DB_URL=postgresql://app:change-me-strong-postgres-password@db-user:5432/user_db
SECRET_EXAM_DB_URL=postgresql://app:change-me-strong-postgres-password@db-exam:5432/exam_db
SECRET_COURSE_DB_URL=postgresql://app:change-me-strong-postgres-password@db-course:5432/course_db
SECRET_QUESTION_DB_URL=postgresql://app:change-me-strong-postgres-password@db-question:5432/question_db
SECRET_NOTIFICATION_DB_URL=postgresql://app:change-me-strong-postgres-password@db-notification:5432/notification_db
SECRET_ANALYTICS_DB_URL=postgresql://app:change-me-strong-postgres-password@db-analytics:5432/analytics_db
SECRET_SIMULATION_DB_URL=postgresql://app:change-me-strong-postgres-password@db-simulation:5432/simulation_db
SECRET_MEDIA_DB_URL=postgresql://app:change-me-strong-postgres-password@db-media:5432/media_db
SECRET_AUDIT_DB_URL=postgresql://app:change-me-strong-postgres-password@db-audit:5432/audit_db
SECRET_RABBITMQ_URL=amqp://app:change-me-strong-rabbitmq-password@rabbitmq:5672
SECRET_RABBITMQ_USERNAME=app
SECRET_RABBITMQ_PASSWORD=change-me-strong-rabbitmq-password
SECRET_KEYCLOAK_CLIENT_SECRET=change-me-keycloak-client-secret

REDIS_URL=redis://redis:6379
QUESTION_SERVICE_URL=http://question-service:3000
USER_SERVICE_URL=http://user-service:3000

STORAGE_ACCOUNT_NAME=change-me
STORAGE_ACCOUNT_KEY=change-me
SECRET_STORAGE_ACCOUNT_KEY=change-me
STORAGE_CONTAINER_NAME=media
STORAGE_PRESIGNED_URL_EXPIRY=3600

KEYCLOAK_SMTP_HOST=smtp.gmail.com
KEYCLOAK_SMTP_PORT=587
KEYCLOAK_SMTP_AUTH=true
KEYCLOAK_SMTP_USER=change-me
KEYCLOAK_SMTP_PASSWORD=change-me
KEYCLOAK_SMTP_SSL=false
KEYCLOAK_SMTP_STARTTLS=true
KEYCLOAK_SMTP_FROM=no-reply@example.com
KEYCLOAK_SMTP_FROM_DISPLAY_NAME=Luyen Thi Lai Xe IDrive
KEYCLOAK_SMTP_REPLY_TO=no-reply@example.com
KEYCLOAK_SMTP_REPLY_TO_DISPLAY_NAME=Luyen Thi Lai Xe IDrive

LOGSTASH_HOST=logstash
LOGSTASH_PORT=5044
LOG_CONSOLE_FORMAT=json
ELASTICSEARCH_URL=http://elasticsearch:9200
KIBANA_URL=http://kibana:5601
PROMETHEUS_URL=http://prometheus:9090
ALERTMANAGER_URL=http://alertmanager:9093
ALERTMANAGER_WEBHOOK_URL=http://host.docker.internal:9099/alertmanager
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-strong-grafana-password

BACKUP_RETENTION_DAYS=7
BACKUP_WEEKLY_RETENTION_WEEKS=4
BACKUP_INTERVAL_SECONDS=86400

KEYCLOAK_TIMEOUT_MS=10000
QUESTION_SERVICE_TIMEOUT_MS=3000
USER_SERVICE_TIMEOUT_MS=3000
