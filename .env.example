# Local/development defaults. Copy to .env and override real values locally.
NODE_ENV=development-local

# Shared infrastructure
POSTGRES_USER=user
POSTGRES_PASSWORD=password
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_ERLANG_COOKIE=change-me-local-cookie
REDIS_URL=redis://localhost:6379
NOTIFICATION_WARNING_RETRY_INTERVAL_MS=300000

# Database names
IDENTITY_DB_NAME=identity_db
USER_DB_NAME=user_db
EXAM_DB_NAME=exam_db
COURSE_DB_NAME=course_db
QUESTION_DB_NAME=question_db
NOTIFICATION_DB_NAME=notification_db
ANALYTICS_DB_NAME=analytics_db
SIMULATION_DB_NAME=simulation_db
MEDIA_DB_NAME=media_db
AUDIT_DB_NAME=audit_db

# Keycloak
KEYCLOAK_DB_NAME=keycloak_db
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=luyen-thi-lai-xe-realm
KEYCLOAK_CLIENT_ID=nestjs-backend
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_TIMEOUT_MS=10000
KEYCLOAK_COMMAND=start-dev --import-realm
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_HOSTNAME_STRICT=false
KEYCLOAK_HTTP_ENABLED=true
KEYCLOAK_PROXY_HEADERS=xforwarded

# Optional Keycloak SMTP integration
KEYCLOAK_SMTP_HOST=mailpit
KEYCLOAK_SMTP_PORT=1025
KEYCLOAK_SMTP_AUTH=false
KEYCLOAK_SMTP_USER=
KEYCLOAK_SMTP_PASSWORD=
KEYCLOAK_SMTP_SSL=false
KEYCLOAK_SMTP_STARTTLS=false
KEYCLOAK_SMTP_FROM=no-reply@luyen-thi-lai-xe.local
KEYCLOAK_SMTP_FROM_DISPLAY_NAME=Luyen Thi Lai Xe IDrive
KEYCLOAK_SMTP_REPLY_TO=no-reply@luyen-thi-lai-xe.local
KEYCLOAK_SMTP_REPLY_TO_DISPLAY_NAME=Luyen Thi Lai Xe IDrive

# Optional media storage. Leave account fields empty to boot without blob storage.
STORAGE_ACCOUNT_NAME=
STORAGE_ACCOUNT_KEY=
STORAGE_CONTAINER_NAME=media
STORAGE_PRESIGNED_URL_EXPIRY=3600

# Public URLs and CORS defaults
PUBLIC_BIND=0.0.0.0
PRIVATE_BIND=127.0.0.1
VPS_PUBLIC_HOST=localhost
GATEWAY_PUBLIC_URL=http://localhost:8000
KEYCLOAK_PUBLIC_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:3000
KONG_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3009,http://localhost:4173,http://localhost:5173,http://localhost:5174,http://localhost:4200,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3009,http://127.0.0.1:4173,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:4200

# Observability
LOG_LEVEL=debug
LOG_FORMAT=text
LOGSTASH_HOST=127.0.0.1
LOGSTASH_PORT=5044
LOGSTASH_HOST_PORT=5044
LOG_CONSOLE_FORMAT=json
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3009,http://localhost:4173,http://localhost:5173,http://localhost:5174,http://localhost:4200,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3009,http://127.0.0.1:4173,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:4200
ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601
PROMETHEUS_URL=http://localhost:9090
ALERTMANAGER_URL=http://localhost:9093
ALERTMANAGER_WEBHOOK_URL=http://host.docker.internal:9099/alertmanager
GRAFANA_URL=http://localhost:30000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
ES_JAVA_OPTS=-Xms512m -Xmx512m

# Published service ports
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001
KEYCLOAK_PORT=8080
CONSUL_PORT=8500
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_PROMETHEUS_PORT=15692
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=30000

# Backup
BACKUP_RETENTION_DAYS=7
BACKUP_WEEKLY_RETENTION_WEEKS=4
BACKUP_INTERVAL_SECONDS=86400

# Service-to-service timeouts
QUESTION_SERVICE_TIMEOUT_MS=3000
USER_SERVICE_TIMEOUT_MS=3000

# Image/deploy defaults
GHCR_OWNER=nhactaohocbai
IMAGE_TAG=latest

# Remote deployment command inputs. Keep real tokens in your shell, CI, or secret store.
DEPLOY_ENV=production
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PATH=/opt/luyen-thi-lai-xe
GHCR_USERNAME=
GHCR_TOKEN=
PRISMA_CLI_VERSION=7.8.0

# Consul seed placeholders for staging/production.
# In real environments, inject these through GitHub/Jenkins/cloud secrets.
QUESTION_SERVICE_URL=http://question-service:3000
USER_SERVICE_URL=http://user-service:3000
SECRET_IDENTITY_DB_URL=postgresql://user:password@db-identity:5432/identity_db
SECRET_USER_DB_URL=postgresql://user:password@db-user:5432/user_db
SECRET_EXAM_DB_URL=postgresql://user:password@db-exam:5432/exam_db
SECRET_COURSE_DB_URL=postgresql://user:password@db-course:5432/course_db
SECRET_QUESTION_DB_URL=postgresql://user:password@db-question:5432/question_db
SECRET_NOTIFICATION_DB_URL=postgresql://user:password@db-notification:5432/notification_db
SECRET_ANALYTICS_DB_URL=postgresql://user:password@db-analytics:5432/analytics_db
SECRET_SIMULATION_DB_URL=postgresql://user:password@db-simulation:5432/simulation_db
SECRET_MEDIA_DB_URL=postgresql://user:password@db-media:5432/media_db
SECRET_AUDIT_DB_URL=postgresql://user:password@db-audit:5432/audit_db
SECRET_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
SECRET_RABBITMQ_USERNAME=guest
SECRET_RABBITMQ_PASSWORD=guest
SECRET_KEYCLOAK_CLIENT_SECRET=change-me
SECRET_STORAGE_ACCOUNT_KEY=
