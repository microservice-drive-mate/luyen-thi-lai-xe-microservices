{
  "staging": {
    "shared": {
      "log.level": "info",
      "log.format": "json",
      "node_env": "staging",
      "observability.logstash.host": "${LOGSTASH_HOST}",
      "observability.logstash.port": "${LOGSTASH_PORT}",
      "observability.elasticsearch.url": "${ELASTICSEARCH_URL}",
      "observability.kibana.url": "${KIBANA_URL}",
      "observability.prometheus.url": "${PROMETHEUS_URL}",
      "observability.alertmanager.url": "${ALERTMANAGER_URL}",
      "observability.grafana.url": "${GRAFANA_URL}",
      "public.gateway.url": "${GATEWAY_PUBLIC_URL:-http://localhost:8000}",
      "public.keycloak.url": "${KEYCLOAK_PUBLIC_URL:-http://localhost:8080}",
      "public.frontend.origin": "${FRONTEND_ORIGIN:-http://localhost:3000}",
      "cors.origins": "${KONG_CORS_ORIGINS:-http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173}"
    },
    "identity-service": {
      "port": "3000",
      "database.url": "${SECRET_IDENTITY_DB_URL}",
      "database.pool_size": "10",
      "database.connection_timeout": "5000",
      "rabbitmq.url": "${SECRET_RABBITMQ_URL}",
      "rabbitmq.username": "${SECRET_RABBITMQ_USERNAME}",
      "rabbitmq.password": "${SECRET_RABBITMQ_PASSWORD}",
      "rabbitmq.vhost": "/",
      "keycloak.authServerUrl": "${KEYCLOAK_AUTH_SERVER_URL}",
      "keycloak.realm": "${KEYCLOAK_REALM}",
      "keycloak.clientId": "${KEYCLOAK_CLIENT_ID}",
      "keycloak.clientSecret": "${SECRET_KEYCLOAK_CLIENT_SECRET}",
      "keycloak.timeoutMs": "10000",
      "smtp.host": "${KEYCLOAK_SMTP_HOST}",
      "smtp.port": "${KEYCLOAK_SMTP_PORT:-587}",
      "smtp.user": "${KEYCLOAK_SMTP_USER}",
      "smtp.pass": "${KEYCLOAK_SMTP_PASSWORD}",
      "smtp.from": "${KEYCLOAK_SMTP_FROM}",
      "smtp.secure": "${KEYCLOAK_SMTP_SSL:-false}",
      "smtp.starttls": "${KEYCLOAK_SMTP_STARTTLS:-true}",
      "push.fcmCredentials": "${FCM_CREDENTIALS:-}"
    },
    "user-service": {
      "port": "3000",
      "database.url": "${SECRET_USER_DB_URL}",
      "rabbitmq.url": "${SECRET_RABBITMQ_URL}",
      "keycloak.authServerUrl": "${KEYCLOAK_AUTH_SERVER_URL}",
      "keycloak.realm": "${KEYCLOAK_REALM}",
      "keycloak.clientId": "${KEYCLOAK_CLIENT_ID}",
      "keycloak.clientSecret": "${SECRET_KEYCLOAK_CLIENT_SECRET}",
      "keycloak.timeoutMs": "10000"
    },
    "exam-service": {
      "port": "3000",
      "database.url": "${SECRET_EXAM_DB_URL}",
      "rabbitmq.url": "${SECRET_RABBITMQ_URL}",
      "keycloak.authServerUrl": "${KEYCLOAK_AUTH_SERVER_URL}",
      "keycloak.realm": "${KEYCLOAK_REALM}",
      "keycloak.clientId": "${KEYCLOAK_CLIENT_ID}",
      "keycloak.clientSecret": "${SECRET_KEYCLOAK_CLIENT_SECRET}",
      "keycloak.timeoutMs": "10000",
      "services.question.baseUrl": "${QUESTION_SERVICE_URL}",
      "services.question.timeoutMs": "3000",
      "services.user.baseUrl": "${USER_SERVICE_URL}",
      "services.user.timeoutMs": "3000"
    },
    "question-service": {
      "port": "3000",
      "database.url": "${SECRET_QUESTION_DB_URL}",
