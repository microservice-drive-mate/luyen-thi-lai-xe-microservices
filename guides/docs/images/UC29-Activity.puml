@startuml UC29-Activity
title UC29 - Send Academic Warnings

skinparam shadowing false
skinparam handwritten false
skinparam backgroundColor white

|Instructor/Admin|
start
:(1) Compose warning message;

|System|
:(2) Validate JWT;
if (JWT valid?) then (Yes)
  :(3) Check [Send_AcademicWarnings] permission;
  if (Has permission?) then (Yes)
    :(4) Validate student list and reason;
    if (Valid?) then (Yes)
      :(5) Load target students;
      if (All exist?) then (Yes)
        :(6) Persist warnings [status=PENDING];
        :(7) Enqueue warning notifications;
        :(8) Update status=QUEUED or PENDING_RETRY;
        :(9) Return MSG112 (HTTP 201);
      else (No)
        :(10) Return MSG111 (HTTP 404);
      endif
    else (No)
      :(11) Return MSG109 (HTTP 400);
    endif
  else (No)
    :(12) Return MSG110 (HTTP 403);
  endif
else (No)
  :(13) Return MSG110 (HTTP 403);
endif

|Instructor/Admin|
:(14) See confirmation;
stop
@enduml