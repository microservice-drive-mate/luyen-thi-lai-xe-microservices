@startuml UC32-Activity
title UC32 - Review Frequently Missed Questions

skinparam shadowing false
skinparam handwritten false
skinparam backgroundColor white

|Student|
start
:(1) Click review button;

|System|
:(2) Validate JWT;
if (JWT valid?) then (Yes)
  :(3) Check [Review_MissedQuestions] permission;
  if (Has permission?) then (Yes)
    :(4) Validate period and set size;
    if (Valid?) then (Yes)
      :(5) Load wrong-answer history;
      if (History exists?) then (Yes)
        :(6) Calculate frequency per question;
        :(7) Score by SRS importance;
        :(8) Generate review set;
        :(9) Return MSG124 (HTTP 200);
      else (No)
        :(10) Return MSG123 (HTTP 404);
      endif
    else (No)
      :(11) Return MSG121 (HTTP 400);
    endif
  else (No)
    :(12) Return MSG122 (HTTP 403);
  endif
else (No)
  :(13) Return MSG122 (HTTP 403);
endif

|Student|
:(14) View review set;
stop
@enduml