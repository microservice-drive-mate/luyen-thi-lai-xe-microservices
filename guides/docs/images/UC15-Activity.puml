@startuml UC15-Activity
title UC15 - View Exam Results

skinparam shadowing false
skinparam handwritten false
skinparam backgroundColor white

|Student|
start
:(1) Click exam result link;
:(2) Request result detail;

|System|
:(3) Validate JWT;
if (JWT valid?) then (Yes)
  :(4) Check [View_ExamResults] permission;
  if (Has permission?) then (Yes)
    :(5) Validate query and ownership scope;
    if (Valid?) then (Yes)
      :(6) Load graded attempt result;
      if (Result exists?) then (Yes)
        :(7) Build response with score, fatal info, feedback;
        :(8) Return MSG56 (HTTP 200);
      else (No)
        :(9) Return MSG55 (HTTP 404);
      endif
    else (No)
      :(10) Return MSG53 (HTTP 400);
    endif
  else (No)
    :(11) Return MSG54 (HTTP 403);
  endif
else (No)
  :(12) Return MSG54 (HTTP 403);
endif

|Student|
:(13) View result detail;
stop
@enduml