@startuml UC18-Activity
title UC18 - Create Question

skinparam shadowing false
skinparam handwritten false
skinparam backgroundColor white

|Admin/Manager|
start
:(1) Fill question form;
:(2) Click [btnCreateQuestion];

|System|
:(3) Validate JWT;
if (JWT valid?) then (Yes)
  :(4) Check [Create_Question] permission;
  if (Has permission?) then (Yes)
    :(5) Validate question fields;
    if (Valid?) then (Yes)
      :(6) Load context for duplicate detection;
      if (Context exists?) then (Yes)
        :(7) Persist question record;
        :(8) Update cache/index;
        :(9) Return MSG68 (HTTP 201);
      else (No)
        :(10) Return MSG67 (HTTP 404);
      endif
    else (No)
      :(11) Return MSG65 (HTTP 400);
    endif
  else (No)
    :(12) Return MSG66 (HTTP 403);
  endif
else (No)
  :(13) Return MSG66 (HTTP 403);
endif

|Admin/Manager|
:(14) See result;
stop
@enduml