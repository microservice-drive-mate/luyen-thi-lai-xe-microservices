@startuml UC28-Activity
title UC28 - Reset Learning Progress

skinparam shadowing false
skinparam handwritten false
skinparam backgroundColor white

|Student|
start
:(1) Click [btnResetProgress];

|System|
:(2) Validate JWT;
if (JWT valid?) then (Yes)
  :(3) Check [Reset_LearningProgress] permission;
  if (Has permission?) then (Yes)
    :(4) Validate reset policy and cooldown;
    if (Policy satisfied?) then (Yes)
      :(5) Load student progress scope;
      if (Scope exists?) then (Yes)
        :(6) Reset progress markers and counters;
        :(7) Restore baseline state;
        :(8) Return MSG108 (HTTP 200);
      else (No)
        :(9) Return MSG107 (HTTP 404);
      endif
    else (No)
      :(10) Return MSG105 (HTTP 400);
    endif
  else (No)
    :(11) Return MSG106 (HTTP 403);
  endif
else (No)
  :(12) Return MSG106 (HTTP 403);
endif

|Student|
:(13) See result;
stop
@enduml